{
  "name": "the publisher",
  "nodes": [
    {
      "parameters": {
        "content": "## Contract\nReceives the Express app payload: `{ batch_id, posting_date, timezone, callback_url, jobs[] }`.\n\nThis workflow is an executor only. It must not create queue rows and must never call `POST /api/queue`.\n\nThe webhook responds immediately after validation, before splitting jobs, waiting, publishing, or commenting."
      },
      "id": "note-contract",
      "name": "Contract Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        -1240,
        -360
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "fb-publisher",
        "authentication": "headerAuth",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-app-jobs",
      "name": "Webhook: App Jobs",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        -1240,
        -40
      ],
      "webhookId": "fb-publisher-app-jobs",
      "credentials": {
        "httpHeaderAuth": {
          "name": "Webhook Secret"
        }
      }
    },
    {
      "parameters": {
        "keepOnlySet": false,
        "values": {
          "string": [
            {
              "name": "app_base_url",
              "value": "REPLACE_WITH_PUBLIC_APP_URL"
            }
          ]
        },
        "options": {}
      },
      "id": "config-node",
      "name": "Config",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [
        -1020,
        -40
      ]
    },
    {
      "parameters": {
        "jsCode": "const incoming = $input.first().json;\nconst body = incoming.body || incoming;\nconst appBaseUrl = incoming.app_base_url || 'REPLACE_WITH_PUBLIC_APP_URL';\n\nif (!body.batch_id) throw new Error('Missing batch_id');\nif (!body.posting_date) throw new Error('Missing posting_date');\nif (!Array.isArray(body.jobs) || body.jobs.length === 0) {\n  throw new Error('Expected payload.jobs to contain at least one job');\n}\nif (!appBaseUrl || appBaseUrl === 'REPLACE_WITH_PUBLIC_APP_URL') {\n  throw new Error('Set Config.app_base_url to your public Express app URL before activating this workflow.');\n}\n\nconst callbackPath = body.callback_url || '/api/queue/status';\nconst callbackUrl = /^https?:\\/\\//.test(callbackPath)\n  ? callbackPath\n  : `${appBaseUrl.replace(/\\/$/, '')}${callbackPath.startsWith('/') ? callbackPath : `/${callbackPath}`}`;\n\nfor (const job of body.jobs) {\n  const label = `queue_id=${job.queue_id ?? 'missing'}`;\n  if (!job.queue_id) throw new Error(`${label}: missing queue_id`);\n  if (!job.page_id) throw new Error(`${label}: missing page_id`);\n  if (!job.content_type) throw new Error(`${label}: missing content_type`);\n  if (!['photo', 'reel'].includes(job.content_type)) throw new Error(`${label}: unsupported content_type ${job.content_type}`);\n  if (!job.media_url) throw new Error(`${label}: missing media_url`);\n  if (!job.scheduled_time) throw new Error(`${label}: missing scheduled_time`);\n}\n\nreturn [{\n  json: {\n    success: true,\n    batch_id: body.batch_id,\n    posting_date: body.posting_date,\n    timezone: body.timezone || 'Africa/Cairo',\n    callback_url: callbackUrl,\n    job_count: body.jobs.length,\n    jobs: body.jobs\n  }\n}];"
      },
      "id": "validate-batch",
      "name": "Validate Batch Contract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -800,
        -40
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.error !== undefined }}",
              "value2": true
            }
          ]
        }
      },
      "id": "check-validation-error",
      "name": "Check Validation Error",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        -580,
        -40
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"success\": false,\n  \"error\": \"{{ $json.error.message }}\"\n}",
        "options": {}
      },
      "id": "respond-invalid",
      "name": "Respond: Invalid Payload",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        -340,
        -200
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\n  \"accepted\": true,\n  \"batch_id\": \"{{ $json.batch_id }}\",\n  \"jobs_received\": {{ $json.job_count }}\n}",
        "options": {}
      },
      "id": "respond-accepted",
      "name": "Respond: Jobs Accepted",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [
        -340,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "const batch = $input.first().json;\nreturn batch.jobs.map(job => ({\n  json: {\n    ...job,\n    batch_id: job.batch_id || batch.batch_id,\n    timezone: batch.timezone,\n    callback_url: batch.callback_url\n  }\n}));"
      },
      "id": "split-jobs",
      "name": "Split payload.jobs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -340,
        -40
      ]
    },
    {
      "parameters": {
        "jsCode": "const validated = $('Validate Batch Contract').item.json;\nreturn [{ json: validated }];"
      },
      "id": "load-validated-batch-after-response",
      "name": "Load Validated Batch After Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -120,
        120
